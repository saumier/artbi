<%# Rendered via AJAX into the event details modal %>

<%# Image ──────────────────────────────────────────────────── %>
<% if details[:image].present? %>
  <div class="ev-modal__image-wrap">
    <img src="<%= details[:image] %>" alt="" class="ev-modal__image" loading="lazy">
  </div>
<% end %>

<div class="ev-modal__detail-body">

  <%# Date & time ─────────────────────────────────────────── %>
  <% if details[:start_date].present? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Date</span>
      <p class="ev-modal__meta-value ev-modal__date-line">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="ev-modal__meta-icon">
          <rect x="1.5" y="2.5" width="13" height="12" rx="1.5"/>
          <path d="M1.5 6.5h13M5 1.5v2M11 1.5v2" stroke-linecap="round"/>
        </svg>
        <span>
          <%= details[:start_date] %>
          <% if details[:end_date].present? %>
            <span class="ev-modal__date-sep">→</span> <%= details[:end_date] %>
          <% end %>
          <% if details[:start_time].present? %>
            <span class="ev-modal__time-sep">·</span> <%= details[:start_time] %>
          <% end %>
        </span>
      </p>
    </div>
  <% end %>

  <%# Venue ───────────────────────────────────────────────── %>
  <% if details[:location_name].present? || details[:city].present? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Lieu</span>
      <p class="ev-modal__meta-value ev-modal__venue-line">
        <svg viewBox="0 0 16 16" fill="currentColor" class="ev-modal__meta-icon">
          <path d="M8 1a5 5 0 00-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 00-5-5zm0 7a2 2 0 110-4 2 2 0 010 4z"/>
        </svg>
        <span>
          <% if details[:location_name].present? %>
            <strong><%= details[:location_name] %></strong>
          <% end %>
          <% if details[:city].present? || details[:province].present? %>
            <span class="ev-modal__venue-location">
              <%= [details[:city], details[:province]].compact.join(", ") %>
            </span>
          <% end %>
        </span>
      </p>
    </div>
  <% end %>

  <%# Description ─────────────────────────────────────────── %>
  <% if details[:description].present? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Description</span>
      <div class="ev-modal__description ev-modal__description--collapsed">
        <%= raw details[:description] %>
      </div>
      <button class="ev-modal__read-more"
              data-action="click->event-modal#expandDescription">
        Lire la suite
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  <% end %>

  <%# Status ──────────────────────────────────────────────── %>
  <% if details[:status].present? && details[:status] != "EventScheduled" %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Statut</span>
      <span class="ev-card__status ev-card__status--<%= details[:status].underscore.dasherize %>">
        <%= case details[:status]
            when "EventCancelled" then "Annulé"
            when "EventPostponed" then "Reporté"
            else details[:status]
            end %>
      </span>
    </div>
  <% end %>

  <%# Types ───────────────────────────────────────────────── %>
  <% if details[:types].any? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Type d'événement</span>
      <div class="ev-modal__tags">
        <% details[:types].each do |t| %>
          <%= link_to t[:label], concept_filter_path(t[:uri], t[:label]),
                class: "ev-chip ev-chip--link" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Performers ──────────────────────────────────────────── %>
  <% if details[:performers].any? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Artistes / Interprètes</span>
      <p class="ev-modal__meta-value"><%= details[:performers].join(", ") %></p>
    </div>
  <% end %>

  <%# Organizers ──────────────────────────────────────────── %>
  <% if details[:organizers].any? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Organisateurs</span>
      <p class="ev-modal__meta-value"><%= details[:organizers].join(", ") %></p>
    </div>
  <% end %>

  <%# Keywords ────────────────────────────────────────────── %>
  <% if details[:keywords].any? %>
    <div class="ev-modal__meta-row">
      <span class="ev-modal__meta-label">Mots-clés</span>
      <div class="ev-modal__tags">
        <% details[:keywords].each do |kw| %>
          <span class="ev-chip"><%= kw %></span>
        <% end %>
      </div>
    </div>
  <% end %>

</div>

<%# Links footer (moved to fixed footer by Stimulus) ────── %>
<div class="ev-modal__links">
  <% if details[:url].present? %>
    <a href="<%= details[:url] %>"
       target="_blank"
       rel="noopener noreferrer"
       class="ev-btn ev-btn--primary">
      Site officiel
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 3.5H3.5A1.5 1.5 0 002 5v7.5A1.5 1.5 0 003.5 14H11a1.5 1.5 0 001.5-1.5V10M9 2h5m0 0v5m0-5L8 9"/>
      </svg>
    </a>
  <% end %>

  <% details[:same_as].each do |link| %>
    <a href="<%= link %>"
       target="_blank"
       rel="noopener noreferrer"
       class="ev-btn ev-btn--outline">
      <%= social_label(link) %>
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 3.5H3.5A1.5 1.5 0 002 5v7.5A1.5 1.5 0 003.5 14H11a1.5 1.5 0 001.5-1.5V10M9 2h5m0 0v5m0-5L8 9"/>
      </svg>
    </a>
  <% end %>

  <% kid = artsdata_kid(details[:uri]) %>
  <% if kid %>
    <a href="http://kg.artsdata.ca/resource/<%= kid %>"
       target="_blank"
       rel="noopener noreferrer"
       class="ev-btn ev-btn--artsdata"
       title="Voir sur Artsdata.ca">
      <img src="https://kg.artsdata.ca/favicon.ico"
           alt=""
           class="ev-modal__artsdata-favicon"
           width="12" height="12"
           aria-hidden="true">
      <span class="ev-modal__kid"><%= kid %></span>
    </a>
  <% end %>
</div>
