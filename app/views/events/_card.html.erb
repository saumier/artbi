<article class="ev-card">

  <%# Image ────────────────────────────────────────────────── %>
  <div class="ev-card__media">
    <% if event[:image].present? %>
      <img src="<%= event[:image] %>"
           alt="<%= event[:name] %>"
           class="ev-card__img"
           loading="lazy">
    <% else %>
      <div class="ev-card__placeholder" aria-hidden="true">
        <span><%= event[:name]&.gsub(/\b(\w)/, '\1')&.scan(/[A-Z]/)&.first(2)&.join || "?" %></span>
      </div>
    <% end %>
    <% if event[:type].present? %>
      <span class="ev-card__badge"><%= event[:type] %></span>
    <% end %>
  </div>

  <%# Body ─────────────────────────────────────────────────── %>
  <div class="ev-card__body">
    <% if event[:start_date] %>
      <div class="ev-card__date-block">
        <time datetime="<%= event[:start_date].iso8601 %>" class="ev-card__date">
          <span class="ev-card__date-day"><%= event[:start_date].strftime("%-d") %></span>
          <span class="ev-card__date-month"><%= event[:start_date].strftime("%b") %></span>
          <span class="ev-card__date-year"><%= event[:start_date].strftime("%Y") %></span>
        </time>
        <% if event[:end_date] && event[:end_date].to_date != event[:start_date].to_date %>
          <span class="ev-card__date-sep">→</span>
          <time datetime="<%= event[:end_date].iso8601 %>" class="ev-card__date ev-card__date--end">
            <span class="ev-card__date-day"><%= event[:end_date].strftime("%-d") %></span>
            <span class="ev-card__date-month"><%= event[:end_date].strftime("%b") %></span>
          </time>
        <% end %>
      </div>
    <% end %>

    <h3 class="ev-card__title"><%= event[:name] %></h3>

    <% if event[:location_name].present? || event[:city].present? %>
      <p class="ev-card__venue">
        <svg class="ev-card__venue-icon" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        <span>
          <% if event[:location_name].present? %>
            <span class="ev-card__venue-name"><%= event[:location_name] %></span>
          <% end %>
          <% if event[:city].present? %>
            <span class="ev-card__venue-city"><%= event[:city] %></span>
          <% end %>
        </span>
      </p>
    <% end %>

    <% status = event[:status] %>
    <% if status.present? && status != "EventScheduled" %>
      <p class="ev-card__status ev-card__status--<%= status.underscore.dasherize %>">
        <%= status == "EventCancelled" ? "Annulé" : status == "EventPostponed" ? "Reporté" : status %>
      </p>
    <% end %>

    <div class="ev-card__footer">
      <% if event[:url].present? %>
        <a href="<%= event[:url] %>"
           target="_blank"
           rel="noopener noreferrer"
           class="ev-btn ev-btn--sm ev-btn--ghost">
          Détails
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 3.5H3.5A1.5 1.5 0 002 5v7.5A1.5 1.5 0 003.5 14H11a1.5 1.5 0 001.5-1.5V10M9 2h5m0 0v5m0-5L8 9"/>
          </svg>
        </a>
      <% end %>
    </div>
  </div>

</article>
